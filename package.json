{
  "name": "codeherway-platform",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check": "npm run check:quality && npm run test:unit",
    "check:ci": "npm run check && npm run test:integration",
    "check:quality": "npm run lint && npm run check:js-source && npm run audit:e2e-scripts && npm run check:supabase-readiness && npm run build && npm run check:bundle && npm run audit:lesson-labels && npm run audit:quizzes && npm run audit:content",
    "check:bundle": "node scripts/check-bundle-size.mjs",
    "check:supabase-readiness": "node scripts/check-supabase-readiness.mjs",
    "audit:e2e-scripts": "node scripts/audit-playwright-projects.mjs",
    "audit:quizzes": "node scripts/audit-quiz-integrity.mjs --strict",
    "audit:content": "node scripts/audit-learning-content.mjs",
    "audit:lesson-labels": "node scripts/check-lesson-labels.mjs",
    "check:js-source": "node scripts/check-js-source-policy.mjs",
    "test": "npm run test:unit",
    "test:unit": "vitest run",
    "test:run": "vitest run",
    "test:watch": "vitest",
    "test:integration": "playwright test",
    "test:a11y": "npm run test:a11y:unit && npm run test:a11y:e2e",
    "test:a11y:unit": "vitest run src/components/auth/AuthPage.a11y.test.jsx src/components/layout/Sidebar.a11y.test.jsx",
    "test:a11y:e2e": "playwright test tests/e2e/accessibility.smoke.spec.js",
    "test:e2e": "npm run test:integration",
    "test:e2e:smoke": "npm run test:e2e:smoke:public && npm run test:e2e:smoke:learning",
    "test:e2e:smoke:public": "playwright test tests/e2e/accessibility.smoke.spec.js tests/e2e/auth.smoke.spec.js tests/e2e/public-learning-entry.spec.js --project=chromium --project=mobile-chrome",
    "test:e2e:smoke:learning": "node scripts/run-auth-e2e-smoke.mjs",
    "test:e2e:smoke:lesson": "playwright test tests/e2e/lesson-flow.spec.js --project=authenticated-chromium",
    "test:e2e:smoke:mobile": "playwright test tests/e2e/mobile-learning-smoke.spec.js --project=authenticated-mobile-chrome",
    "test:e2e:smoke:authenticated": "playwright test tests/e2e/authenticated.smoke.spec.js --project=authenticated-chromium",
    "test:e2e:auth:preflight": "node scripts/auth-e2e-preflight.mjs",
    "test:e2e:update-snapshots": "playwright test --update-snapshots",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install chromium",
    "test:e2e:report": "playwright show-report",
    "test:policy": "vitest run src/integration/supabase-policy.test.js",
    "test:lighthouse": "npx @lhci/cli@0.15.x autorun --config=./lighthouserc.json"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource/poppins": "^5.2.7",
    "@fontsource/space-mono": "^5.2.9",
    "@monaco-editor/react": "^4.7.0",
    "@sentry/react": "^10.51.0",
    "@supabase/supabase-js": "^2.105.3",
    "@testing-library/dom": "^10.4.1",
    "jspdf": "^4.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.15.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "vite": "^8.0.10",
    "vitest": "^4.1.5",
    "vitest-axe": "^0.1.0"
  },
  "overrides": {
    "dompurify": "^3.4.2"
  }
}
