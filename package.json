{
  "name": "codeherway-platform",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check": "npm run check:quality && npm run test:unit",
    "check:ci": "npm run check && npm run test:integration",
    "check:quality": "npm run lint && npm run build && npm run check:bundle",
    "check:bundle": "node scripts/check-bundle-size.mjs",
    "typecheck": "node scripts/check-js-source-policy.mjs",
    "test": "npm run test:unit",
    "test:unit": "vitest run",
    "test:run": "vitest run",
    "test:watch": "vitest",
    "test:integration": "playwright test",
    "test:a11y": "npm run test:a11y:unit && npm run test:a11y:e2e",
    "test:a11y:unit": "vitest run src/components/auth/AuthPage.a11y.test.jsx src/components/layout/Sidebar.a11y.test.jsx",
    "test:a11y:e2e": "playwright test tests/e2e/accessibility.smoke.spec.js",
    "test:e2e": "npm run test:integration",
    "test:e2e:update-snapshots": "playwright test --update-snapshots",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install chromium",
    "test:e2e:report": "playwright show-report",
    "test:policy": "vitest run src/integration/supabase-policy.test.js",
    "test:lighthouse": "npx @lhci/cli@0.15.x autorun --config=./lighthouserc.json"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource/poppins": "^5.2.7",
    "@fontsource/space-mono": "^5.2.9",
    "@monaco-editor/react": "^4.7.0",
    "@sentry/react": "^10.49.0",
    "@supabase/supabase-js": "^2.49.1",
    "jspdf": "^4.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.5.0",
    "jsdom": "^25.0.1",
    "vite": "^6.0.0",
    "vitest": "^4.1.4",
    "vitest-axe": "^0.1.0"
  },
  "overrides": {
    "dompurify": "^3.3.3"
  }
}
