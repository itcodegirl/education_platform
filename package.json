{
  "name": "codeherway-platform",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --configLoader runner",
    "generate:search-manifest": "node scripts/generate-search-manifest.mjs",
    "build": "vite build --configLoader runner",
    "preview": "vite preview",
    "generate:reference": "node scripts/generate-reference-data.mjs",
    "scaffold:legacy-lesson": "node scripts/migrate-legacy-lesson.mjs",
    "lint": "node scripts/run-eslint.mjs .",
    "typecheck": "node scripts/typecheck.mjs",
    "lint:fix": "node scripts/run-eslint.mjs . --fix",
    "check": "npm run check:quality && npm run test:unit",
    "check:ci": "npm run check && npm run test:integration",
    "check:quality": "npm run lint && npm run check:js-source && npm run check:search-manifest && npm run audit:e2e-scripts && npm run audit:auth-e2e && npm run check:supabase-readiness && npm run audit:reward-catalog && npm run audit:staging-runbook && npm run audit:lighthouse-evidence && npm run audit:screenshot-guide && npm run audit:launch-readiness-templates && npm run build && npm run check:bundle && npm run check:route-boundaries && npm run audit:lesson-labels && npm run audit:lesson-format && npm run audit:quizzes && npm run audit:content",
    "audit:performance": "npm run build && npm run check:bundle && npm run check:route-boundaries && npm run report:bundle && npm run report:bundle-review",
    "check:bundle": "node scripts/check-bundle-size.mjs",
    "report:bundle": "node scripts/write-bundle-summary.mjs",
    "report:bundle-review": "node scripts/write-bundle-review-summary.mjs",
    "check:route-boundaries": "node scripts/check-route-boundaries.mjs",
    "check:search-manifest": "node scripts/check-search-manifest.mjs",
    "check:supabase-readiness": "node scripts/check-supabase-readiness.mjs",
    "audit:staging-runbook": "node scripts/check-staging-validation-runbook.mjs",
    "audit:lighthouse-evidence": "node scripts/check-lighthouse-evidence.mjs",
    "audit:screenshot-guide": "node scripts/check-screenshot-guide.mjs",
    "audit:launch-readiness-templates": "node scripts/check-launch-readiness-templates.mjs",
    "audit:package-scripts": "node scripts/check-package-scripts.mjs",
    "audit:e2e-scripts": "node scripts/audit-playwright-projects.mjs",
    "audit:auth-e2e": "node scripts/audit-auth-e2e-readiness.mjs",
    "audit:reward-catalog": "node scripts/check-reward-catalog.mjs",
    "audit:quizzes": "node scripts/audit-quiz-integrity.mjs --strict",
    "audit:content": "node scripts/audit-learning-content.mjs",
    "audit:content:budget": "node scripts/audit-learning-content.mjs --summary --budget scripts/audit-learning-content-budget.json",
    "audit:lesson-labels": "node scripts/check-lesson-labels.mjs",
    "audit:lesson-format": "node scripts/audit-lesson-format.mjs",
    "check:js-source": "node scripts/check-js-source-policy.mjs",
    "test": "npm run test:unit",
    "test:unit": "vitest run --configLoader runner",
    "test:run": "vitest run --configLoader runner",
    "test:watch": "vitest --configLoader runner",
    "test:integration": "playwright test",
    "test:a11y": "npm run test:a11y:unit && npm run test:a11y:e2e",
    "test:a11y:unit": "vitest run --configLoader runner src/components/auth/AuthPage.a11y.test.jsx src/components/layout/Sidebar.a11y.test.jsx src/components/shared/ProfilePage.a11y.test.jsx src/styles/lessonTasks.a11y.test.js",
    "test:a11y:e2e": "playwright test tests/e2e/accessibility.smoke.spec.js tests/e2e/authenticated.accessibility.spec.js",
    "test:e2e": "npm run test:integration",
    "test:e2e:smoke": "npm run test:e2e:smoke:public && npm run test:e2e:smoke:learning",
    "test:e2e:smoke:public": "node scripts/run-public-e2e-smoke.mjs",
    "test:e2e:visual:public": "node scripts/run-public-playwright.mjs tests/e2e/public.visual.spec.js --project=mobile-chrome",
    "test:e2e:smoke:learning": "node scripts/run-auth-e2e-smoke.mjs",
    "test:e2e:smoke:lesson": "node scripts/run-auth-e2e-smoke.mjs lesson",
    "test:e2e:smoke:mobile": "node scripts/run-auth-e2e-smoke.mjs mobile",
    "test:e2e:smoke:authenticated": "node scripts/run-auth-e2e-smoke.mjs authenticated",
    "test:e2e:auth:preflight": "node scripts/auth-e2e-preflight.mjs",
    "test:e2e:update-snapshots": "playwright test --update-snapshots",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install chromium",
    "test:e2e:report": "playwright show-report",
    "test:policy": "vitest run --configLoader runner src/integration/supabase-policy.test.js",
    "test:lighthouse": "npm run test:lighthouse:desktop && npm run test:lighthouse:mobile",
    "test:lighthouse:desktop": "npx @lhci/cli@0.15.x autorun --config=./lighthouserc.json",
    "test:lighthouse:mobile": "npx @lhci/cli@0.15.x autorun --config=./lighthouserc.mobile.json"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource/poppins": "^5.2.7",
    "@fontsource/space-mono": "^5.2.9",
    "@monaco-editor/react": "^4.7.0",
    "@sentry/react": "^10.53.1",
    "@supabase/supabase-js": "^2.105.4",
    "@testing-library/dom": "^10.4.1",
    "jspdf": "^4.2.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "vite": "^8.0.12",
    "vitest": "^4.1.6",
    "vitest-axe": "^0.1.0"
  },
  "overrides": {
    "dompurify": "^3.4.2"
  }
}
