# Authenticated Playwright E2E template.
# Duplicate this file as .env.e2e.local for local signed-in smoke runs.
# The .env.e2e.local file is ignored by git.

VITE_SUPABASE_URL=https://your-e2e-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-e2e-project-anon-key
E2E_EMAIL=learner@example.com
E2E_PASSWORD=replace-with-dedicated-test-password

# Leave false for normal local runs so missing credentials self-skip.
# Set true when you want local preflight to fail closed.
E2E_AUTH_REQUIRED=false

# Keep false unless you are intentionally testing against a local Supabase stack.
E2E_ALLOW_LOCAL_SUPABASE=false
