# ═══════════════════════════════════════════════
# CodeHerWay — Environment Variables
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════

# ─── Required: Supabase ───────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ─── Optional: AI Tutor ──────────────────────
# Direct API key (for development only — use a proxy in production)
VITE_ANTHROPIC_API_KEY=

# Backend proxy URL (recommended for production — hides API key server-side)
# If set, AI requests go here instead of directly to Anthropic
VITE_AI_PROXY_URL=

# ─── Optional: Error Monitoring ──────────────
# Get your DSN from: https://sentry.io → Project Settings → Client Keys
VITE_SENTRY_DSN=
