VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Server-side only — set these in Netlify dashboard > Site settings > Environment variables
# NEVER put these in client-side code or commit actual values.
#
# The AI Tutor is backed by OpenAI (not Anthropic). All calls are proxied
# through netlify/functions/ai.js so the API key never reaches the browser.
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
# Service-role key is required by the AI function's persistent rate limiter.
# It bypasses RLS — keep it server-side only.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
