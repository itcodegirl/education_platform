# ─── Client-side (VITE_*) ──────────────────────────────────────────────
# These get baked into the browser bundle at build time, so they MUST NOT
# contain any secret value. The Supabase "anon" key is designed to be
# public — the real access control lives in Row-Level Security policies
# on the database itself (see supabase-schema.sql).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ─── Server-side ONLY ──────────────────────────────────────────────────
# Set these in Netlify dashboard > Site settings > Environment variables.
# NEVER prefix them with VITE_ (that would ship them to the browser).
# NEVER commit real values to git.
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# Service-role key for the streak-reminder scheduled function.
# This key bypasses RLS — treat it like a database password.
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# Shared secret required to manually POST to the streak-reminder
# function. Scheduled invocations from Netlify bypass this check.
STREAK_REMINDER_SECRET=generate-a-long-random-string
