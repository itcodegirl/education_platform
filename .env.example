# ─── Client-side (VITE_*) ──────────────────────────────────────────────
# These get baked into the browser bundle at build time, so they MUST NOT
# contain any secret value. The Supabase "anon" key is designed to be
# public — the real access control lives in Row-Level Security policies
# on the database itself (see supabase-schema.sql).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Optional backend reward engine.
# Keep disabled until reward_events + award_reward_event migrations are applied.
VITE_REWARD_BACKEND_SYNC_ENABLED=false

# Optional analytics ingestion.
# Keep disabled unless Netlify analytics-ingest + Supabase analytics tables are configured.
VITE_ANALYTICS_ENABLED=false
VITE_ANALYTICS_DEBUG=false

# Optional: production error tracking (Sentry)
# Enabled by default in production when VITE_SENTRY_DSN is set.
VITE_SENTRY_DSN=
VITE_SENTRY_ENABLED=true
VITE_SENTRY_ENVIRONMENT=production
VITE_SENTRY_RELEASE=
VITE_SENTRY_TRACES_SAMPLE_RATE=0

# ─── Server-side ONLY ──────────────────────────────────────────────────
# Set these in Netlify dashboard > Site settings > Environment variables.
# NEVER prefix them with VITE_ (that would ship them to the browser).
# NEVER commit real values to git.
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# Service-role key for the streak-reminder scheduled function.
# This key bypasses RLS — treat it like a database password.
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# Shared secret required to manually POST to the streak-reminder
# function. Scheduled invocations from Netlify bypass this check.
STREAK_REMINDER_SECRET=generate-a-long-random-string
